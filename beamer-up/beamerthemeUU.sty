% beamerthemeUU.sty - legacy-named implementation file for the beamer-up derivative
% Public project identity: beamer-up
% Approved first-release public theme identifier: UP
% Canonical public usage: \usetheme{UP}
% Direct legacy usage retained as deprecated compatibility: \usetheme{UU}
% Attribution: derived from the original beamer-uu work by A.J.H. (Jos) Zuijderwijk; independently maintained here by Zildjian E. California.
% Branding note: distributed UP-branded assets should follow the UP branding guidelines and are intended for UP constituents/internal use. No official endorsement is implied.
%
% Transitional options:
%   nl            - switch to the legacy Dutch-logo compatibility path
%   english       - use the English UP logotype (default)
%   filipino      - use the Unibersidad ng Pilipinas logotype
%   showlogo      - show the approved corner logo on content slides
%   nosectionpage - suppress automatic section divider slides
%
% Transitional helper commands:
%   \standoutframe{Text}
%   \thankframe{Title}{Contact}
%   \venue{Conference, City}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeUU}[2026/04/01 Legacy-named theme package for the beamer-up derivative]

\@ifundefined{beamerup@loadedfromupwrapper}{%
  \PackageWarningNoLine{beamerthemeUU}{Direct legacy theme loading is deprecated.\MessageBreak
    Load the theme with \string\usetheme{UP} instead of \string\usetheme{UU}.}%
}{}

% -- Options -----------------------------------------------------------
\newif\if@UUnosection\@UUnosectionfalse
\newif\if@UUnl\@UUnlfalse
\newif\if@UUfilipino\@UUfilipinofalse
\newif\if@UUshowlogo\@UUshowlogofalse

\DeclareOption{nosectionpage}{\@UUnosectiontrue}
\DeclareOption{nl}{\@UUnltrue}
\DeclareOption{english}{\@UUfilipinofalse}
\DeclareOption{filipino}{\@UUfilipinotrue}
\DeclareOption{tagalog}{\@UUfilipinotrue}
\DeclareOption{showlogo}{\@UUshowlogotrue}
\ProcessOptions\relax

% -- Sub-themes ----------------------------------------------------------
\usecolortheme{UU}
\useinnertheme{UU}
\useoutertheme{UU}

% -- Code listings --------------------------------------------------------
\RequirePackage{listings}
\lstset{
  basicstyle=\ttfamily\footnotesize,
  keywordstyle=\bfseries\color{UPMaroon},
  stringstyle=\color{UPForestGreen},
  commentstyle=\itshape\color{UPBlack80},
  numberstyle=\tiny\color{UPBlack80},
  backgroundcolor=\color{UPGoldTint},
  frame=none,
  numbers=left,
  numbersep=8pt,
  breaklines=true,
  showstringspaces=false,
  tabsize=2,
  xleftmargin=1.5em,
}

% -- bibliography -----------------------------------------------------------
\usepackage[
  backend=biber,
  style=numeric,
  sorting=none
]{biblatex}

\addbibresource{references.bib}

% -- Font setup -----------------------------------------------------------
% UP Typeface Guidelines Hierarchy:
%   - Optima: for titles and headings (official documents)
%   - Palatino: for body text (official documents)
%   - Avenir/Helvetica: for unofficial documents and materials
%
% This theme implements a tiered fallback strategy:
%   1. Optima (preferred for headings per UP guidelines)
%   2. Avenir (acceptable alternative for unofficial materials)
%   3. Helvetica (widely available fallback)
%
% Engine detection: XeLaTeX/LuaLaTeX can access system fonts directly.
% pdfLaTeX uses the fallback chain with TeX font packages.

\usepackage[T1]{fontenc}
\usepackage{palatino} % Body text per UP guidelines
\renewcommand{\familydefault}{\rmdefault}

% Engine detection helper (works across LaTeX formats)
\newcommand{\up@xetex@or@luatex@font@setup}{%
  \typeout{beamerthemeUU: XeLaTeX/LuaLaTeX engine detected, attempting Optima...}%
}%

% Detect engine and load appropriate sans-serif for headings
\ifxetex
  % XeLaTeX: try Optima first, then Avenir, then Helvetica
  \IfFontExistsTF{Optima}{%
    \usepackage{fontspec}
    \setmainfont{Palatino Linotype}
    \setsansfont{Optima}
    \newcommand{\upheadingfont}{\fontspec{Optima}}
    \typeout{beamerthemeUU: Using Optima for headings (UP guidelines compliant)}
  }{%
    \IfFontExistsTF{Avenir}{%
      \usepackage{fontspec}
      \setmainfont{Palatino Linotype}
      \setsansfont{Avenir}
      \newcommand{\upheadingfont}{\fontspec{Avenir}}
      \typeout{beamerthemeUU: Using Avenir for headings (Optima not available)}
    }{%
      \usepackage{fontspec}
      \setmainfont{Palatino Linotype}
      \setsansfont{Helvetica}
      \newcommand{\upheadingfont}{\fontspec{Helvetica}}
      \typeout{beamerthemeUU: Using Helvetica for headings (Optima/Avenir not available)}
    }%
  }%
\else
  \ifluatex
    % LuaLaTeX: try Optima first, then Avenir, then Helvetica
    \IfFontExistsTF{Optima}{%
      \usepackage{fontspec}
      \setmainfont{Palatino}
      \setsansfont{Optima}
      \newcommand{\upheadingfont}{\fontspec{Optima}}
      \typeout{beamerthemeUU: Using Optima for headings (UP guidelines compliant)}
    }{%
      \IfFontExistsTF{Avenir}{%
        \usepackage{fontspec}
        \setmainfont{Palatino}
        \setsansfont{Avenir}
        \newcommand{\upheadingfont}{\fontspec{Avenir}}
        \typeout{beamerthemeUU: Using Avenir for headings (Optima not available)}
      }{%
        \usepackage{fontspec}
        \setmainfont{Palatino}
        \setsansfont{Helvetica}
        \newcommand{\upheadingfont}{\fontspec{Helvetica}}
        \typeout{beamerthemeUU: Using Helvetica for headings (Optima/Avenir not available)}
      }%
    }%
  \else
    % pdfLaTeX fallback: use Helvetica (most widely available)
    % Users wanting Optima should compile with XeLaTeX or LuaLaTeX
    \IfFileExists{helvet.sty}{%
      \usepackage[scaled=0.94]{helvet}%
      \newcommand{\upheadingfont}{\sffamily}%
      \typeout{beamerthemeUU: Using Helvetica for headings (pdfLaTeX engine; use XeLaTeX/LuaLaTeX for Optima)}%
    }{%
      \newcommand{\upheadingfont}{\sffamily}%
      \typeout{beamerthemeUU: Using default sans-serif for headings (helvet.sty not found)}%
    }%
  \fi
\fi

\usefonttheme{professionalfonts}

% Apply heading font consistently across all title/heading elements
\setbeamerfont{title}{family=\upheadingfont, series=\bfseries, size=\LARGE}
\setbeamerfont{subtitle}{family=\upheadingfont, series=\mdseries, size=\normalsize}
\setbeamerfont{frametitle}{family=\upheadingfont, series=\bfseries, size=\large}
\setbeamerfont{author}{family=\rmfamily, size=\normalsize}
\setbeamerfont{institute}{family=\rmfamily, size=\small}
\setbeamerfont{date}{family=\rmfamily, size=\small}
\setbeamerfont{block title}{family=\upheadingfont, series=\bfseries, size=\normalsize}
\setbeamerfont{footline}{family=\upheadingfont, size=\scriptsize}
\setbeamerfont{caption}{size=\footnotesize}
\setbeamerfont{footnote}{size=\tiny}

% -- Default logo paths (based on nl option) ---------------------------
\if@UUnl
  \renewcommand{\@uulogopath}{logos/UU_logo_NL_RGB}
  \renewcommand{\@uulogoblackpath}{logos/UU_logo_NL_ZWART}
  \renewcommand{\@uulogowhitepath}{}
  \renewcommand{\@uulogoinclude}[1]{\includegraphics[height=#1]{\@uulogopath}}
  \renewcommand{\@uulogoblackinclude}[1]{\includegraphics[height=#1]{\@uulogoblackpath}}
  \renewcommand{\@uulogowhiteinclude}[1]{\includegraphics[height=#1]{\@uulogowhitepath}}
\else
  % The UP logotype PNGs are re-cropped into runtime assets so the outer/inner
  % themes can place them deterministically without large transparent padding.
  \if@UUfilipino
    \renewcommand{\@uulogopath}{logos/up-logotype-tag-runtime-black.png}
    \renewcommand{\@uulogoblackpath}{logos/up-logotype-tag-runtime-black.png}
    \renewcommand{\@uulogowhitepath}{logos/up-logotype-tag-runtime-white.png}
    \renewcommand{\@uutitlelogoinclude}[1]{%
      \includegraphics[height=#1]{logos/up-inline-logo-tag-runtime-black.png}}
    \renewcommand{\@uutitlelogosize}{0.84cm}
    \renewcommand{\@uulogoinclude}[1]{%
      \includegraphics[width=#1]{\@uulogopath}}
    \renewcommand{\@uulogoblackinclude}[1]{%
      \includegraphics[width=#1]{\@uulogoblackpath}}
    \renewcommand{\@uulogowhiteinclude}[1]{%
      \includegraphics[width=#1]{\@uulogowhitepath}}
  \else
    \renewcommand{\@uulogopath}{logos/up-logotype-eng-runtime-black.png}
    \renewcommand{\@uulogoblackpath}{logos/up-logotype-eng-runtime-black.png}
    \renewcommand{\@uulogowhitepath}{logos/up-logotype-eng-runtime-white.png}
    \renewcommand{\@uutitlelogoinclude}[1]{%
      \includegraphics[height=#1]{logos/up-inline-logo-eng-runtime-black.png}}
    \renewcommand{\@uutitlelogosize}{0.84cm}
    \renewcommand{\@uulogoinclude}[1]{%
      \includegraphics[width=#1]{\@uulogopath}}
    \renewcommand{\@uulogoblackinclude}[1]{%
      \includegraphics[width=#1]{\@uulogoblackpath}}
    \renewcommand{\@uulogowhiteinclude}[1]{%
      \includegraphics[width=#1]{\@uulogowhitepath}}
  \fi
  \renewcommand{\@uutitlelogoxshift}{1.22cm}
  \renewcommand{\@uutitlelogoyshift}{-0.68cm}
  \renewcommand{\@uutitlecontenttopskip}{2.55cm}
  \renewcommand{\@uutitlecontentwidth}{12.2cm}
\fi

% -- Numbered captions (Table 1, Figure 1, ...) ---------------------------
